@model List<EventPlanner.Web.Models.Inscripcion>
@{
    ViewBag.Title = "Inscritos por Evento";
    var evento = ViewBag.Evento as EventPlanner.Web.Models.Evento;
}

<style>
    .table-reporte th {
        background-color: #00843D !important;
        color: white !important;
        font-weight: 600;
    }

    @@media print {
        header, footer, nav, .sidebar, .navbar, .btn, button, .d-flex .btn, .d-flex gap-2 {
            display: none !important;
        }

        body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }

        .container, .container-fluid, main, .card, .card-body {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            box-shadow: none !important;
            background: white !important;
            overflow: visible !important;
        }

        .table-responsive {
            overflow: visible !important;
            overflow-x: visible !important;
            display: block !important;
            width: 100% !important;
        }

        .table-reporte {
            width: 100% !important;
            table-layout: fixed !important;
            border-collapse: collapse !important;
            margin-top: 20px !important;
            font-size: 10px !important;
        }

            .table-reporte th {
                background-color: #00843D !important;
                color: white !important;
                padding: 8px 4px !important;
                border: 1px solid #333333 !important;
                text-transform: uppercase;
                font-size: 9px !important;
            }

            .table-reporte td {
                padding: 6px 4px !important;
                border: 1px solid #dddddd !important;
                vertical-align: middle !important;
            }

            .table-reporte th, .table-reporte td {
                word-wrap: break-word !important;
                white-space: normal !important;
            }

                .table-reporte th:nth-child(1), .table-reporte td:nth-child(1) {
                    width: 4% !important;
                }

                .table-reporte th:nth-child(2), .table-reporte td:nth-child(2) {
                    width: 18% !important;
                }

                .table-reporte th:nth-child(3), .table-reporte td:nth-child(3) {
                    width: 20% !important;
                }

                .table-reporte th:nth-child(4), .table-reporte td:nth-child(4) {
                    width: 9% !important;
                }

                .table-reporte th:nth-child(5), .table-reporte td:nth-child(5) {
                    width: 23% !important;
                }

                .table-reporte th:nth-child(6), .table-reporte td:nth-child(6) {
                    width: 10% !important;
                }

                .table-reporte th:nth-child(7), .table-reporte td:nth-child(7) {
                    width: 8% !important;
                }

                .table-reporte th:nth-child(8), .table-reporte td:nth-child(8) {
                    width: 8% !important;
                }

            .table-reporte tbody tr:nth-child(even) {
                background-color: #f9f9f9 !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Inscritos: @(evento!=null?evento.NombreEvento:"")</h4>
        @if (evento != null)
        {<small class="text-muted">@evento.FechaEvento.ToString("dd/MM/yyyy") - @evento.Lugar</small>}
    </div>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">Imprimir</button>
        <a href="@Url.Action("Eventos","Reporte")" class="btn btn-outline-secondary btn-sm">Volver</a>
    </div>
</div>
<div class="card">
    <div class="card-header card-header-ep d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Listado de Inscritos</span>
        <span class="badge bg-light text-dark">@(Model!=null?Model.Count:0) inscritos</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-reporte table-hover mb-0">
                <thead>
                    <tr><th>#</th><th>Nombre</th><th>Correo</th><th>Ficha</th><th>Programa</th><th>Modalidad</th><th>Equipo</th><th>F. Inscripcion</th></tr>
                </thead>
                <tbody>
                    @if (Model == null || Model.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Sin inscritos.</td></tr>
                    }
                    else
                    {
                        int n = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@n</td>
                                <td class="fw-semibold">@item.NombreUsuario</td>
                                <td>@item.CorreoUsuario</td>
                                <td>@item.FichaUsuario</td>
                                <td>@item.ProgramaUsuario</td>
                                <td>@item.Modalidad</td>
                                <td>@(string.IsNullOrEmpty(item.NombreEquipo)?"---":item.NombreEquipo)</td>
                                <td>@item.FechaInscripcion.ToString("dd/MM/yyyy")</td>
                            </tr>
                            n++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
