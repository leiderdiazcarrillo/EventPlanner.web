<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - EventPlanner SENA</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        :root {
            --verde: #00843D;
            --verde-oscuro: #005a2b;
        }

        body {
            background: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            padding: 0;
        }

        /* NAVBAR */
        .navbar-ep {
            background-color: var(--verde) !important;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }

            .navbar-ep .navbar-brand {
                font-weight: 700;
                font-size: 1.25rem;
                color: #fff !important;
            }

            .navbar-ep .nav-link {
                color: rgba(255,255,255,.9) !important;
                font-weight: 500;
            }

                .navbar-ep .nav-link:hover {
                    color: #fff !important;
                    background: rgba(255,255,255,.15);
                    border-radius: 6px;
                }

            .navbar-ep .dropdown-menu {
                border: none;
                box-shadow: 0 4px 166px rgba(0,0,0,.15);
            }

            .navbar-ep .dropdown-item:hover {
                background: #e8f5ee;
                color: var(--verde);
            }

        .navbar-toggler-icon {
            filter: invert(1);
        }

        /* SIDEBAR */
        .sidebar {
            width: 240px;
            min-height: calc(100vh - 56px);
            background: #fff;
            border-right: 1px solid #dee2e6;
            padding: 1rem 0;
            position: fixed;
            top: 56px;
            left: -240px;
            z-index: 200;
            box-shadow: 2px 0 8px rgba(0,0,0,.05);
            transition: left .25s ease;
        }

            .sidebar.sidebar-open {
                left: 0;
            }

        @@media (min-width: 768px) {
            .sidebar {
                left: 0;
            }
        }

        .sidebar .nav-link {
            color: #495057;
            padding: .55rem 1.4rem;
            border-radius: 0;
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .92rem;
        }

            .sidebar .nav-link:hover {
                background: #e8f5ee;
                color: var(--verde);
            }

        .sidebar .sidebar-title {
            font-size: .7rem;
            font-weight: 700;
            color: #adb5bd;
            text-transform: uppercase;
            letter-spacing: .08em;
            padding: .5rem 1.4rem;
            margin-top: .5rem;
        }

        /* SIDEBAR TOGGLE BUTTON (mobile) */
        .sidebar-toggle-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,.2);
            border: none;
            color: #fff;
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 1.2rem;
            cursor: pointer;
            margin-right: 8px;
        }

        @@media (min-width: 768px) {
            .sidebar-toggle-btn {
                display: none;
            }
        }

        /* SIDEBAR OVERLAY */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.4);
            z-index: 199;
        }

            .sidebar-overlay.active {
                display: block;
            }

        /* MAIN CONTENT */
        .main-with-sidebar {
            margin-left: 0;
            padding: 1.5rem 1rem;
            min-height: calc(100vh - 56px);
            transition: margin-left .25s ease;
        }

        @@media (min-width: 768px) {
            .main-with-sidebar {
                margin-left: 240px;
                padding: 1.5rem;
            }
        }

        .main-full {
            padding: 1.5rem 1rem;
            min-height: calc(100vh - 56px);
        }

        @@media (min-width: 768px) {
            .main-full {
                padding: 1.5rem;
            }
        }

        /* CARDS */
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 10px rgba(0,0,0,.07);
        }

        .card-header-ep {
            background: var(--verde);
            color: #fff;
            border-radius: 12px 12px 0 0 !important;
        }

        .btn-ep {
            background: var(--verde);
            color: #fff;
            border: none;
        }

            .btn-ep:hover {
                background: var(--verde-oscuro);
                color: #fff;
            }

        /* STATS */
        .stat-card {
            border-radius: 12px;
            padding: 1.25rem;
            color: #fff;
        }

            .stat-card h2 {
                font-size: 2.2rem;
                font-weight: 700;
                margin: 0;
            }

            .stat-card p {
                margin: 0;
                opacity: .85;
                font-size: .9rem;
            }

        /* BADGES */
        .badge-activo {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-inactivo {
            background: #fee2e2;
            color: #991b1b;
        }

        /* SIDEBAR PROFILE */
        .sidebar-profile {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1.25rem 1rem 1rem;
            border-bottom: 1px solid #dee2e6;
            margin-bottom: .5rem;
        }

            .sidebar-profile img {
                width: 72px;
                height: 72px;
                border-radius: 50%;
                object-fit: cover;
                border: 3px solid var(--verde);
                margin-bottom: .5rem;
            }

            .sidebar-profile .perfil-nombre {
                font-weight: 700;
                font-size: .92rem;
                text-align: center;
                color: #212529;
                line-height: 1.3;
            }

            .sidebar-profile .perfil-rol {
                font-size: .78rem;
                color: #6c757d;
                margin-top: .1rem;
            }

        .sidebar .nav-link.active, .sidebar .nav-link.active:hover {
            background: #d1fae5;
            color: var(--verde);
            font-weight: 600;
        }

        .field-error {
            border-color: #dc3545 !important;
        }

        .field-ok {
            border-color: #198754 !important;
        }

        .val-msg {
            font-size: .8rem;
            margin-top: .2rem;
            min-height: 1rem;
        }

            .val-msg.error {
                color: #dc3545;
            }

            .val-msg.ok {
                color: #198754;
            }

        /* TABLES RESPONSIVENESS */
        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        /* FORMS */
        .form-control, .form-select {
            max-width: 100%;
        }

        /* CHATBOT */
        #chatbot-toggle {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: var(--verde);
            color: #fff;
            border: none;
            font-size: 1.5rem;
            box-shadow: 0 4px 16px rgba(0,0,0,.3);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform .2s;
        }

            #chatbot-toggle:hover {
                transform: scale(1.08);
                background: var(--verde-oscuro);
            }

        #chatbot-box {
            position: fixed;
            bottom: 90px;
            right: 24px;
            z-index: 9998;
            width: min(340px, calc(100vw - 32px));
            height: min(480px, calc(100vh - 120px));
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,.18);
            display: none;
            flex-direction: column;
            overflow: hidden;
        }

            #chatbot-box.open {
                display: flex;
            }

        #chatbot-header {
            background: var(--verde);
            color: #fff;
            padding: .75rem 1rem;
            font-weight: 600;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        #chatbot-msgs {
            flex: 1;
            overflow-y: auto;
            padding: .75rem;
            display: flex;
            flex-direction: column;
            gap: .5rem;
            background: #f8fafb;
        }

        .msg-bot, .msg-user {
            max-width: 85%;
            padding: .5rem .75rem;
            border-radius: 12px;
            font-size: .875rem;
            line-height: 1.4;
            word-break: break-word;
        }

        .msg-bot {
            background: #e8f5ee;
            color: #1a1a1a;
            align-self: flex-start;
            border-bottom-left-radius: 4px;
        }

        .msg-user {
            background: var(--verde);
            color: #fff;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }

        .msg-typing {
            opacity: .6;
            font-style: italic;
        }

        #chatbot-footer {
            padding: .6rem;
            border-top: 1px solid #dee2e6;
            display: flex;
            gap: .4rem;
        }

        #chatbot-input {
            flex: 1;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: .45rem .7rem;
            font-size: .875rem;
            outline: none;
        }

            #chatbot-input:focus {
                border-color: var(--verde);
            }

        #chatbot-send {
            background: var(--verde);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .45rem .8rem;
            cursor: pointer;
            font-size: .9rem;
        }

            #chatbot-send:hover {
                background: var(--verde-oscuro);
            }

        footer {
            padding: 1rem 0;
            border-top: 1px solid #dee2e6;
            color: #6c757d;
            font-size: .82rem;
            text-align: center;
            margin-top: 2rem;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-md navbar-ep fixed-top">
        <div class="container-fluid">
            @if (Session["Rol"] != null && (Session["Rol"].ToString() == "ADMIN" || Session["Rol"].ToString() == "APRENDIZ"))
            {
                <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Abrir menu">&#9776;</button>
            }
            @Html.ActionLink("EventPlanner SENA", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            <button class="navbar-toggler border-white" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navMain" aria-expanded="false">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <div class="ms-auto d-flex align-items-center gap-2">
                    <span class="text-white small fw-bold">Servicio Nacional de Aprendizaje - SENA</span>
                    <img src="https://upload.wikimedia.org/wikipedia/commons/8/83/Sena_Colombia_logo.svg" alt="Logo SENA" style="height: 32px; width: 32px; filter: brightness(0) invert(1);" />
                </div>
            </div>
        </div>
    </nav>

    <div style="margin-top:56px;">
        @if (Session["Rol"] != null && Session["Rol"].ToString() == "ADMIN")
        {
            <div class="sidebar-overlay" id="sidebarOverlay"></div>

            <div class="sidebar" id="sidebar">
                <div class="sidebar-profile">
                    @{ string fotoAdmin = Session["FotoPerfil"] as string; }
                    <img src="@(string.IsNullOrEmpty(fotoAdmin) ? "/Content/Fotos/default-avatar.svg" : fotoAdmin)"
                         alt="Foto perfil" />
                    <div class="perfil-nombre">@Session["Nombre"]</div>
                    <div class="perfil-rol">Admin</div>
                </div>

                <div class="sidebar-title">Principal</div>
                <a href="@Url.Action("Dashboard","Admin")" class="nav-link">&#x1F4CA; Dashboard</a>
                <div class="sidebar-title">Eventos</div>
                <a href="@Url.Action("Index","Evento")" class="nav-link">&#x1F4CB; Gestionar Eventos</a>
                <a href="@Url.Action("Crear","Evento")" class="nav-link">&#x2795; Crear Evento</a>
                <a href="@Url.Action("Index","Equipo")" class="nav-link">&#x1F465; Gestionar Equipos</a>
                <div class="sidebar-title">Reportes</div>
                <a href="@Url.Action("Eventos","Reporte")" class="nav-link">&#x1F4C4; Reporte Eventos</a>
                <a href="@Url.Action("Inscripciones","Reporte")" class="nav-link">&#x1F4DD; Reporte Inscripciones</a>
                <div class="sidebar-title">Cuenta</div>
                <a href="@Url.Action("VerPerfil","Usuario")" class="nav-link">&#x1F464; Ver Perfil</a>
                <a href="@Url.Action("Logout","Usuario")" class="nav-link" style="color:#dc3545;">&#x1F6AA; Cerrar Sesion</a>
            </div>
            <div class="main-with-sidebar">
                @RenderBody()
                <footer>&copy; @DateTime.Now.Year EventPlanner - SENA Centro para la Industria Petroquimica</footer>
            </div>
        }
        else if (Session["Rol"] != null && Session["Rol"].ToString() == "APRENDIZ")
        {
            <div class="sidebar-overlay" id="sidebarOverlay"></div>

            <div class="sidebar" id="sidebar">
                <div class="sidebar-profile">
                    @{ string fotoAprendiz = Session["FotoPerfil"] as string; }
                    <img src="@(string.IsNullOrEmpty(fotoAprendiz) ? "/Content/Fotos/default-avatar.svg" : fotoAprendiz)"
                         alt="Foto perfil" />
                    <div class="perfil-nombre">@Session["Nombre"]</div>
                    <div class="perfil-rol">Aprendiz</div>
                </div>

                <div class="sidebar-title">Principal</div>
                <a href="@Url.Action("EventosDisponibles","Inscripcion")" class="nav-link">&#x1F4C5; Eventos Disponibles</a>
                <a href="@Url.Action("MisInscripciones","Inscripcion")" class="nav-link">&#x1F4CB; Mis Inscripciones</a>
                <div class="sidebar-title">Cuenta</div>
                <a href="@Url.Action("VerPerfil","Usuario")" class="nav-link">&#x1F464; Ver Perfil</a>
                <a href="@Url.Action("Logout","Usuario")" class="nav-link" style="color:#dc3545;">&#x1F6AA; Cerrar Sesion</a>
            </div>
            <div class="main-with-sidebar">
                @RenderBody()
                <footer>&copy; @DateTime.Now.Year EventPlanner - SENA Centro para la Industria Petroquimica</footer>
            </div>
        }
        else
        {
            <div class="main-full">
                @RenderBody()
                <footer>&copy; @DateTime.Now.Year EventPlanner - SENA Centro para la Industria Petroquimica</footer>
            </div>
        }
    </div>

    <button id="chatbot-toggle" title="Asistente EventPlanner">&#x1F4AC;</button>
    <div id="chatbot-box">
        <div id="chatbot-header">
            <span>Asistente EventPlanner</span>
            <button onclick="document.getElementById('chatbot-box').classList.remove('open')"
                    style="background:none;border:none;color:#fff;font-size:1.1rem;cursor:pointer;">
                &#x2715;
            </button>
        </div>
        <div id="chatbot-msgs">
            <div class="msg-bot">Hola, soy el asistente de EventPlanner SENA. Puedo ayudarte con informacion sobre eventos, inscripciones, equipos y el uso del sistema. Escribe tu pregunta.</div>
        </div>
        <div id="chatbot-footer">
            <input id="chatbot-input" type="text" placeholder="Escribe tu pregunta..." maxlength="300" />
            <button id="chatbot-send">&#x27A4;</button>
        </div>
    </div>

    <script src="https://jquery.com"></script>
    <script src="https://jsdelivr.net"></script>
    <script src="https://cloudflare.com"></script>
    <script src="https://cloudflare.com"></script>

    @RenderSection("scripts", required: false)

    <script>
        // Sidebar toggle (mobile)
        (function () {
            var toggle = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('sidebar');
            var overlay = document.getElementById('sidebarOverlay');
            if (!toggle) return;
            function open() { sidebar.classList.add('sidebar-open'); overlay.classList.add('active'); }
            function close() { sidebar.classList.remove('sidebar-open'); overlay.classList.remove('active'); }
            toggle.addEventListener('click', function () {
                sidebar.classList.contains('sidebar-open') ? close() : open();
            });
            overlay.addEventListener('click', close);
        })();

        // Chatbot
        (function () {
            var btn = document.getElementById('chatbot-toggle');
            var box = document.getElementById('chatbot-box');
            var msgs = document.getElementById('chatbot-msgs');
            var input = document.getElementById('chatbot-input');
            var send = document.getElementById('chatbot-send');

            btn.addEventListener('click', function () { box.classList.toggle('open'); });

            function addMsg(text, who) {
                var div = document.createElement('div');
                div.className = who === 'bot' ? 'msg-bot' : 'msg-user';
                div.textContent = text;
                msgs.appendChild(div);
                msgs.scrollTop = msgs.scrollHeight;
                return div;
            }

            function enviar() {
                var q = input.value.trim();
                if (!q) return;
                addMsg(q, 'user');
                input.value = '';
                var typing = addMsg('Escribiendo...', 'bot');
                typing.classList.add('msg-typing');
                fetch('/Chatbot/Responder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'pregunta=' + encodeURIComponent(q)
                })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        typing.remove();
                        addMsg(data.respuesta || 'No pude obtener una respuesta.', 'bot');
                    })
                    .catch(function () {
                        typing.remove();
                        addMsg('Error al conectar con el asistente. Intenta de nuevo.', 'bot');
                    });
            }

            send.addEventListener('click', enviar);
            input.addEventListener('keydown', function (e) { if (e.key === 'Enter') enviar(); });
        })();
    </script>
</body>
</html>